generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  photo     String?
  jobDesk   String
  role      String   // "Admin" | "Staff"
  telegramUsername String? // Untuk integrasi webhook telegram
  handledAreas String[] // Untuk auto-assign Master Data
  tasks     Task[]
  timeLogs  TimeLog[]
  supportTickets SupportTicket[] @relation("SupportCreator")
  assignedSupportTickets SupportTicket[] @relation("SupportExecutors")
  assignedSchedules      MaintenanceSchedule[] @relation("ScheduleExecutors")
  maintenanceLogs        MaintenanceLog[]
  picAssets              Asset[]
  comments       Comment[]
  commentReadStatuses CommentReadStatus[]
  notifications  Notification[]
  createdAt DateTime @default(now())
  lastActiveAt DateTime @default(now())
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  objective   String?
  members     String?
  startDate   DateTime
  endDate     DateTime
  status      String   // "Not Started" | "Ongoing" | "Completed"
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(uuid())
  parentId    String?  // Untuk hierarki task
  projectId   String?
  userId      String
  title       String
  startDate   DateTime
  endDate     DateTime
  priority    String   // "Butuh Cepat" | "Normal"
  issue         String?  // Kendala
  solution      String?  // Solusi
  documentation String?  // Link GDrive/OneDrive
  executor      String?  // Penanggung jawab task
  status        String   // "Not Started" | "Ongoing" | "Completed"
  attachment    String?
  
  project     Project? @relation(fields: [projectId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  parentTask  Task?    @relation("TaskHierarchy", fields: [parentId], references: [id])
  subTasks    Task[]   @relation("TaskHierarchy")
  timeLogs    TimeLog[]
  comments    Comment[]
  commentReadStatuses CommentReadStatus[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TimeLog {
  id          String   @id @default(uuid())
  taskId      String
  userId      String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?     // Total durasi dalam detik

  task        Task     @relation(fields: [taskId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model SupportTicket {
  id            String   @id @default(uuid())
  userId        String
  taskName      String
  supportType   String
  module        String
  area          String?  // Untuk tiket kategori Master Data
  startDate     DateTime
  endDate       DateTime?
  issue         String?
  solution      String?
  status        String
  priority      String   @default("Normal")
  attachment    String?

  // Penambahan Field Baru
  ticketType    String   @default("DAILY_ACTIVITY") // "REQUEST" atau "DAILY_ACTIVITY"
  requesterName String?  // Nama Pelapor (untuk REQUEST)
  executors     User[]   @relation("SupportExecutors")
  link          String?

  user          User     @relation("SupportCreator", fields: [userId], references: [id])
  comments      Comment[]
  commentReadStatuses CommentReadStatus[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Comment {
  id              String   @id @default(uuid())
  content         String
  attachment      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId          String?
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  supportTicketId String?
  supportTicket   SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)

  replyToId       String?
  replyTo         Comment?  @relation("CommentReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         Comment[] @relation("CommentReplies")
}

model CommentReadStatus {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  taskId          String?
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  supportTicketId String?
  supportTicket   SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)
  
  lastReadAt      DateTime @default(now())

  @@unique([userId, taskId])
  @@unique([userId, supportTicketId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // "ASSIGNMENT", "DEADLINE", "SYSTEM", etc.
  isRead    Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// Maintenance Rutin Infrastruktur IT Module
// ==========================================

enum AssetStatus {
  ACTIVE
  IN_REPAIR
  INACTIVE
  RETIRED
}

enum ScheduleType {
  RECURRING
  ADHOC
}

enum ScheduleStatus {
  UPCOMING
  DUE
  OVERDUE
  DONE
}

enum OverallCondition {
  BAIK
  PERLU_PERHATIAN
  BERMASALAH
}

model AssetType {
  id        String   @id @default(uuid())
  name      String   @unique
  assets    Asset[]
  templates MaintenanceTemplate[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Division {
  id        String   @id @default(uuid())
  name      String   @unique
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id              String       @id @default(uuid())
  assetCode       String       @unique
  assetName       String
  assetTypeId     String
  assetType       AssetType    @relation(fields: [assetTypeId], references: [id])
  divisionId      String?
  division        Division?    @relation(fields: [divisionId], references: [id])
  brand           String?
  model           String?
  serialNumber    String?
  person          String?
  location        String?
  detailedLocation String?
  status          AssetStatus  @default(ACTIVE)
  purchaseDate    DateTime?
  warrantyEndDate DateTime?
  picUserId       String?
  pic             User?        @relation(fields: [picUserId], references: [id])
  notes           String?
  schedules       MaintenanceSchedule[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model MaintenanceTemplate {
  id                   String    @id @default(uuid())
  templateName         String
  assetTypeId          String
  assetType            AssetType @relation(fields: [assetTypeId], references: [id])
  defaultFrequencyDays Int
  reminderOffsetDays   Int       // Default otomatis berdasarkan defaultFrequencyDays, bisa di-override Admin
  checklistItems       ChecklistItemMaster[]
  schedules            MaintenanceSchedule[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ChecklistItemMaster {
  id          String              @id @default(uuid())
  templateId  String
  template    MaintenanceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  itemText    String
  order       Int
  isRequired  Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model MaintenanceSchedule {
  id                String         @id @default(uuid())
  scheduleType      ScheduleType
  assetId           String
  asset             Asset          @relation(fields: [assetId], references: [id])
  templateId        String?
  template          MaintenanceTemplate? @relation(fields: [templateId], references: [id])
  frequencyDays     Int?
  nextDueDate       DateTime
  status            ScheduleStatus @default(UPCOMING)
  assignedExecutors User[]         @relation("ScheduleExecutors") // Pattern sama dengan SupportTicket.executors
  logs              MaintenanceLog[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model MaintenanceLog {
  id                String           @id @default(uuid())
  scheduleId        String
  schedule          MaintenanceSchedule @relation(fields: [scheduleId], references: [id])
  executedById      String
  executedBy        User             @relation(fields: [executedById], references: [id])
  executionDate     DateTime         @default(now())
  checklistResults  ChecklistResult[]
  overallCondition  OverallCondition
  findings          String?
  followUpNeeded    Boolean          @default(false)
  supportTicketId   String?          // Relasi opsional ke SupportTicket (String saja, FK di Fase 3)
  attachment        String?
  createdAt         DateTime         @default(now())
}

model ChecklistResult {
  id           String         @id @default(uuid())
  logId        String
  log          MaintenanceLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  itemText     String         // Snapshot dari checklist master saat eksekusi (agar histori tidak berubah jika template diedit)
  checked      Boolean        @default(false)
  note         String?
}
