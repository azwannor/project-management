generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  photo     String?
  jobDesk   String
  role      String   // "Admin" | "Staff"
  tasks     Task[]
  timeLogs  TimeLog[]
  supportTickets SupportTicket[]
  comments       Comment[]
  commentReadStatuses CommentReadStatus[]
  notifications  Notification[]
  createdAt DateTime @default(now())
  lastActiveAt DateTime @default(now())
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  objective   String?
  members     String?
  startDate   DateTime
  endDate     DateTime
  status      String   // "Not Started" | "Ongoing" | "Completed"
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(uuid())
  parentId    String?  // Untuk hierarki task
  projectId   String?
  userId      String
  title       String
  startDate   DateTime
  endDate     DateTime
  priority    String   // "Butuh Cepat" | "Normal"
  issue         String?  // Kendala
  solution      String?  // Solusi
  documentation String?  // Link GDrive/OneDrive
  executor      String?  // Penanggung jawab task
  status        String   // "Not Started" | "Ongoing" | "Completed"
  attachment    String?
  
  project     Project? @relation(fields: [projectId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  parentTask  Task?    @relation("TaskHierarchy", fields: [parentId], references: [id])
  subTasks    Task[]   @relation("TaskHierarchy")
  timeLogs    TimeLog[]
  comments    Comment[]
  commentReadStatuses CommentReadStatus[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TimeLog {
  id          String   @id @default(uuid())
  taskId      String
  userId      String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?     // Total durasi dalam detik

  task        Task     @relation(fields: [taskId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  taskName    String
  supportType String
  module      String
  startDate   DateTime
  endDate     DateTime
  issue       String?
  solution    String?
  status      String
  priority    String   @default("Normal")
  attachment  String?

  user        User     @relation(fields: [userId], references: [id])
  comments    Comment[]
  commentReadStatuses CommentReadStatus[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id              String   @id @default(uuid())
  content         String
  attachment      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId          String?
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  supportTicketId String?
  supportTicket   SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)

  replyToId       String?
  replyTo         Comment?  @relation("CommentReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         Comment[] @relation("CommentReplies")
}

model CommentReadStatus {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  taskId          String?
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  supportTicketId String?
  supportTicket   SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)
  
  lastReadAt      DateTime @default(now())

  @@unique([userId, taskId])
  @@unique([userId, supportTicketId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // "ASSIGNMENT", "DEADLINE", "SYSTEM", etc.
  isRead    Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

